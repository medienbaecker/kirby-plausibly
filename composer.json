{
    "name": "medienbaecker/kirby-plausibly",
    "description": "A native Plausible Analytics dashboard for the Kirby Panel",
    "license": "proprietary",
    "type": "kirby-plugin",
    "keywords": ["kirby", "kirby-plugin", "plausible", "analytics", "panel", "dashboard", "statistics"],
    "authors": [
        {
            "name": "Thomas Günther",
            "email": "mail@medienbaecker.com"
        }
    ],
    "support": {
        "source": "https://github.com/medienbaecker/kirby-plausibly",
        "issues": "https://github.com/medienbaecker/kirby-plausibly/issues"
    },
    "require": {
        "php": "^8.2",
        "getkirby/cms": "^5.0",
        "getkirby/composer-installer": "^1.2"
    },
    "config": {
        "allow-plugins": {
            "getkirby/composer-installer": true
        }
    },
    "archive": {
        "exclude": [
            ".DS_Store",
            ".editorconfig",
            ".gitattributes",
            ".github/",
            ".gitignore",
            "composer.lock",
            "node_modules/",
            "package-lock.json",
            "package.json",
            "src/",
            "vendor/"
        ]
    }
}
